# Copie ce fichier en ".env" et remplis les valeurs.
# Le .env est ignoré par git : tes clés ne seront jamais publiées.
# Clé gratuite : https://www.themoviedb.org/settings/api (compte requis)
VITE_TMDB_API_KEY=

# Project URL + clé anon/public : Supabase → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
